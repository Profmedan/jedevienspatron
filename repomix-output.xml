  <span class="missing-if-branch" title="if path not taken" >I</span>if (cout === 0) <span class="cstat-no" title="statement not covered" >return { succes: true, modifications };</span>
  const push = makePush(joueur, modifications);
&nbsp;
  push("chargesPersonnel", cout, `Salaires commerciaux : +${cout} charges de personnel`);
