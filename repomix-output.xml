                />
              )}
            </>
          )}

          <SectionHeader label="Trésorerie" color={TOOLTIPS.tresorerie.couleur} />
          {tresorerie && (
            <TooltipPoste
              label="Trésorerie"
              value={tresorerie.valeur}
              color={TOOLTIPS.tresorerie.couleur}
              categorie="tresorerie"
              sub
              highlighted={highlightedPoste === "tresorerie"}
