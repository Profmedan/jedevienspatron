def read_donnees_sheet(xlsx_path):
    try:
        wb = load_workbook(xlsx_path)
        sheet = wb['Données']
        data = {}
        for row in sheet.iter_rows():
            for cell in row:
                if cell.value is not None:
                    data[(cell.row, cell.column)] = cell.value
        return data
