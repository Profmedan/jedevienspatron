    if (joueur.bilan.decouvert > types_1.DECOUVERT_MAX) {
        const pénalité = joueur.bilan.decouvert - types_1.DECOUVERT_MAX;
        // CORRECTION BUG : la pénalité s'enregistre en Charges d'intérêt (CR)
