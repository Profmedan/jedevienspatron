              {joueur.bilan.creancesPlus2 > 0 && (
                <TooltipPoste
                  label="Argent à recevoir (dans 2 trim.)"
                  value={joueur.bilan.creancesPlus2}
                  color={TOOLTIPS.creances.couleur}
                  categorie="creances"
                  sub
                  highlighted={highlightedPoste === "creancesPlus2"}
